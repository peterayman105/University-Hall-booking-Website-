{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: install",
      "type": "shell",
      "command": "npm install",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always" }
    },
    {
      "label": "prisma: migrate",
      "type": "shell",
      "command": "npx prisma migrate dev",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always" }
    },
    {
      "label": "prisma: seed",
      "type": "shell",
      "command": "npx prisma db seed",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always" }
    },
    {
      "label": "npm: dev",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "presentation": { "reveal": "always", "focus": true }
    }
  ]
}
